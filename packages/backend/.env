SQL_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER={nazwa serwera};DATABASE={nazwa bazy danych};Trusted_Connection=yes;Connection Timeout=10;

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY={access key w pliku docker compose ustawiony domyślnie na minio}
MINIO_SECRET_KEY={secret key w pliku docker compose ustawiony domyślnie na minio123}
MINIO_BUCKET={nazwa bucketa w pliku docker compose ustawiony domyślnie na photos}
MINIO_PUBLIC_URL={url publiczny domyślnie powinien być http://localhost:9000/photos}

GOOGLE_CLIENT_ID={google client ID}
GOOGLE_CLIENT_SECRET={google client secret}
BACKEND_URL={url pod którym stoi aplikacja backendowa}
FRONTEND_URL={url pod którym stoi aplikacja frontendowa}
JWT_SECRET={wartość sekretu jwt}
ALLOWED_ORIGINS={Adresy na których stoi aplikacja frontendowa}
